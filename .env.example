# ================================================================
# BUSINESS VERIFICATION TELEGRAM BOT
# Railway Production Environment Configuration
# ================================================================
# Di Railway: masukkan semua variable ini di tab "Variables"
# Di VPS: copy ke .env dan edit nilainya
# ================================================================

# === BOT CONFIGURATION ===
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=YourBotUsername
WEBHOOK_DOMAIN=https://yourdomain.com
WEBHOOK_PORT=8443
BOT_PORT=3000

# === SUPER ADMIN ===
SUPER_ADMIN_ID=123456789
SUPER_ADMIN_USERNAME=your_admin_username

# === DATABASE ===
DATABASE_PATH=./data/bot.db
DATABASE_ENCRYPTION_KEY=your_32_char_encryption_key_here_!!

# === ADMIN PANEL ===
ADMIN_PANEL_PORT=4000
ADMIN_PANEL_SECRET=your_super_secret_panel_key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@SecurePass123

# === MAYAR.ID PAYMENT GATEWAY ===
MAYAR_API_KEY=your_mayar_api_key_here
MAYAR_WEBHOOK_SECRET=your_mayar_webhook_secret
MAYAR_BASE_URL=https://api.mayar.id/hl/v1
MAYAR_PRODUCT_ID=your_mayar_product_id

# === VERIFICATION SERVICE ===
VERIFICATION_API_URL=https://your-verification-api.com
VERIFICATION_API_KEY=your_verification_api_key

# === CHANNEL / GROUP SETTINGS ===
REQUIRED_CHANNEL_ID=-100xxxxxxxxxx
REQUIRED_CHANNEL_USERNAME=@yourchannel
REQUIRED_GROUP_ID=-100xxxxxxxxxx
REQUIRED_GROUP_USERNAME=@yourgroup

# === VERIFICATION SETTINGS ===
VERIFICATION_EXPIRE_MINUTES=30
VERIFICATION_CANCEL_MINUTES=3
ORDER_PRICE=10000

# === SECURITY ===
SESSION_SECRET=your_session_secret_here_64_chars_minimum
ENCRYPTION_KEY=your_32_char_encryption_key_secure

# === LOGGING ===
LOG_LEVEL=info
LOG_FILE=./logs/bot.log

# === ENVIRONMENT ===
NODE_ENV=production
